NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use server MySQL instead of browser Supabase.
NEXT_PUBLIC_DATA_PROVIDER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aam_dispatch
DB_USER=dispatcher_ad
DB_PASSWORD=

# Optional: local AI refactor agent. Keep the real key only in .env.local or server secrets.
OPENAI_API_KEY=
OPENAI_REFACTOR_MODEL=gpt-5.4
OPENAI_REFACTOR_MAX_OUTPUT_TOKENS=5000
