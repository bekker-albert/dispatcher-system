NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use server MySQL instead of browser Supabase.
NEXT_PUBLIC_DATA_PROVIDER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aam_dispatch
DB_USER=dispatcher_ad
DB_PASSWORD=

# Optional comma-separated extra origins allowed to call /api/database.
# Production origins https://aam-dispatch.kz and https://www.aam-dispatch.kz are allowed by default.
DATABASE_ALLOWED_ORIGINS=

# Optional: local AI refactor agent. Keep the real key only in .env.local or server secrets.
OPENAI_API_KEY=
OPENAI_REFACTOR_MODEL=gpt-5.4
OPENAI_REFACTOR_MAX_OUTPUT_TOKENS=5000

# Future product AI assistant. Keep real provider secrets only on the server.
AI_ASSISTANT_PROVIDER=
AI_ASSISTANT_MODEL=
AI_ASSISTANT_MAX_OUTPUT_TOKENS=
AI_ASSISTANT_API_KEY=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WEBHOOK_SECRET=
DOCUMENTOLOG_BASE_URL=
DOCUMENTOLOG_CLIENT_ID=
DOCUMENTOLOG_CLIENT_SECRET=
MAIL_SMTP_HOST=
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=
PUSH_PROVIDER_KEY=
KNOWLEDGE_INDEX_URL=
KNOWLEDGE_INDEX_API_KEY=
